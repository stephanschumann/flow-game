rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // FEATURE-001: Spiel-Räume.
    // Löst die sperrende Platzhalter-Regel aus TASK-002 ab
    // (`allow read, write: if false;`).
    //
    // Zugriffsmodell OHNE Cloud Functions (Option B, mit Stephan am
    // 2026-07-17 final abgestimmt, siehe Backlog.md FEATURE-001):
    //   - Jede Person meldet sich anonym per Firebase Authentication an und
    //     bekommt dabei eine stabile UID für ihre Browser-Sitzung.
    //   - Zugehörigkeit zu einem Spiel wird darüber geprüft, ob unter
    //     spiele/{spielId}/teilnehmende/{eigene-uid} ein Dokument existiert.
    //   - Die Host-Rolle wird nach Geräteneuladen/Sitzungsverlust über einen
    //     eigenen Schreibvorgang zurückerobert, der die im Spiel hinterlegte
    //     Host-Kennung als Nachweis verlangt.
    //
    // KORREKTUR (2026-07-17, nach echtem Browser-Test durch Stephan):
    //  1. "Missing or insufficient permissions" beim Spiel-Erstellen: die
    //     Regel für teilnehmende/{uid} (rolle=host) prüfte per get() das
    //     übergeordnete spiele/{spielId}-Dokument, das aber in DERSELBEN
    //     Transaktion gerade erst entsteht und für ein normales get() noch
    //     nicht sichtbar ist. Fix: getAfter() statt get() für genau diesen
    //     Vergleich (liefert den Stand NACH allen Schreibvorgängen im
    //     selben Commit – dokumentierte Firestore-Rules-Funktion für exakt
    //     diesen Fall).
    //  2. Beim Beheben von (1) fiel auf: eine neue, noch nicht beigetretene
    //     Person muss spiele/{spielId} lesen können dürfen (Beitritts-Fluss,
    //     Stationsverfügbarkeit vor dem Beitritt) – das hätte hostKennung
    //     offengelegt, wäre es weiterhin Teil dieses Dokuments gewesen.
    //     Fix: hostKennung liegt jetzt in einem eigenen, nie client-lesbaren
    //     Unterdokument spiele/{spielId}/geheim/kennung.

    function istAktiv(spiel) {
      // Verwaiste Spiele (>24h ohne Aktivität, geklärte Frage 7) sind über
      // die Regeln nicht mehr erreichbar, unabhängig von der TTL-Löschung.
      return spiel.letzteAktivitaet > (request.time.toMillis() - 24 * 60 * 60 * 1000);
    }

    function istTeilnehmer(spielId) {
      // existsAfter() statt exists(): beim Beitreten legt joinGame.js in
      // EINEM Commit sowohl das eigene teilnehmende-Dokument an ALS AUCH
      // das Update von belegteStationen/letzteAktivitaet im spiele-Dokument.
      // exists() sähe dabei nur den Stand VOR diesem Commit (Dokument
      // existiert noch nicht) und würde das Update fälschlich ablehnen –
      // dieselbe Fehlerklasse wie das getAfter()-Problem beim Host-Beitritt
      // weiter oben. existsAfter() prüft den Stand NACH allen Schreib-
      // vorgängen desselben Commits und funktioniert dadurch für beide
      // Fälle (Update im selben Commit wie das Anlegen, oder ein Update zu
      // einem späteren Zeitpunkt, wenn das Dokument längst existiert).
      return request.auth != null
        && existsAfter(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid));
    }

    // FEATURE-002: Rundenzustand + Kartenbewegung. Zusätzliche Helfer-
    // Funktionen, siehe Kommentare bei den runden-/karten-Regeln weiter unten.

    function istHost(spielId) {
      // Bewusst flach gehalten (kein Aufruf von istTeilnehmer() von innen
      // heraus) – existsAfter()/get() direkt hier, konsistent mit dem Muster,
      // das in den bereits freigegebenen FEATURE-001-Regeln erfolgreich läuft
      // (dort ruft ebenfalls nie eine Funktion eine andere Funktion auf).
      return request.auth != null
        && existsAfter(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid))
        && get(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid)).data.get('rolle', null) == 'host';
    }

    // WICHTIG: {runde} ist als Firestore-Pfadsegment (match /runden/{runde})
    // IMMER ein String ("1"/"2"/"3"), nie eine Zahl – deshalb hier bewusst
    // String-Literale statt Zahlen-Literale vergleichen. Ein Vergleich mit
    // Zahlen-Literalen hätte hier für JEDE Runde still auf den else-Zweig (1)
    // durchfallen können, ohne einen Fehler zu werfen (falscher, aber stiller
    // Wert statt korrekt 6/3/1).
    function stapelTorSchwelle(runde) {
      return runde == '1' ? 6 : (runde == '2' ? 3 : 1);
    }

    // Zählt, wie viele der (bis zu) sechs Karten der Runde die `position`
    // BEREITS ERREICHT ODER VERLASSEN haben (position >= die geprüfte
    // Position), optional zusätzlich nach `stapel` gefiltert (Runde 2: die
    // zwei Dreierstapel werden GETRENNT gezählt, Entscheidung 2026-07-18 –
    // kein einmaliges Freischalten über die Gesamtsumme).
    //
    // BUGFIX (2026-07-18, live in Production gefunden beim Bau der
    // Spielbrett-Oberfläche, siehe Abschlussbericht an Stephan): Ursprünglich
    // zählte diese Funktion nur Karten GENAU AN `position` (daten.position ==
    // position). Das öffnet das Tor zwar korrekt beim SECHSTEN Ankommen,
    // schließt es aber sofort wieder, sobald die ERSTE Karte durch das
    // offene Tor weiterzieht (dann stehen nur noch fünf Karten GENAU an
    // `position`, 5 < Schwelle 6) – jede Karte AUSSER der ersten wurde
    // dadurch faelschlich abgelehnt ("Missing or insufficient permissions"),
    // real reproduziert: Karte 1 von Station 1 zu Station 2 gelang, Karten
    // 2-6 scheiterten alle. Fix: `>=` statt `==` – eine Karte, die die
    // Position bereits verlassen hat (an einer höheren Position steht), hat
    // denknotwendig auch `position` durchlaufen und zählt weiterhin für die
    // Tor-Schwelle dieser Position. Einmal offen, bleibt das Tor damit für
    // den Rest der Runde offen, wie in den Akzeptanzkriterien beschrieben.
    //
    // Sicherheitsregeln können keine Sammlungs-Query ausführen (Pre-Mortem-
    // Risiko 3). Da pro Runde immer genau sechs, namentlich bekannte
    // Karten-IDs existieren (karte-1 .. karte-6), werden alle sechs einzeln
    // per get() gelesen und gezählt – das bleibt klar unter dem Limit an
    // get()/exists()-Aufrufen je Regelauswertung.
    function karteAnPositionUndStapel(spielId, runde, kartenId, position, stapel) {
      // OPTIMIERUNG (nach echtem Testlauf mit Stephan, 2026-07-18): kein
      // separates exists()-Vorab-Check mehr - pro Karte nur noch EIN
      // get()-Aufruf statt zwei. Sicher, weil laut Architektur
      // (rundenStart.js) bei jedem Rundenstart immer exakt alle sechs
      // Karten (karte-1..karte-6) ATOMAR zusammen angelegt werden; sobald
      // DoR abgeschlossen ist (Vorbedingung in bewegungErlaubt()),
      // existieren deshalb garantiert alle sechs. Grund: der reale
      // Firestore-Testlauf zeigte "evaluation error ... Function: [exists]"
      // fuer mehrere Kartenbewegungs-/Stapel-Tor-Szenarien - Ursache war
      // das dokumentierte Firestore-Limit von 10 get()/exists()-Aufrufen
      // pro Einzeldokument-Request: die alte Variante (exists() + bedingtes
      // get() je Karte) brauchte bis zu 12 Aufrufe allein fuer die sechs
      // Karten, zusammen mit den uebrigen Aufrufen in bewegungErlaubt()
      // weit ueber dem Limit. Mit nur einem get() je Karte bleibt die
      // gesamte Regelauswertung fuer eine Kartenbewegung bei maximal 9.
      let daten = get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)/karten/$(kartenId)).data;
      return daten.position >= position
        && (stapel == null || daten.get('stapel', null) == stapel)
        ? 1 : 0;
    }

    function anzahlAnPosition(spielId, runde, position, stapel) {
      return karteAnPositionUndStapel(spielId, runde, 'karte-1', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-2', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-3', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-4', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-5', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-6', position, stapel);
    }

    function stapelTorOffen(spielId, runde, vonPosition, stapel) {
      // Der Übergang vom Auftragseingang (Position 0) zu Station 1 ist immer
      // offen, unabhängig von der Rundenschwelle (Entscheidung 2026-07-18) –
      // deshalb hier keine Zählung/kein zusätzlicher get()-Aufwand nötig.
      return vonPosition == 0
        || anzahlAnPosition(spielId, runde, vonPosition, stapel) >= stapelTorSchwelle(runde);
    }

    // Bewegung ist erlaubt, wenn entweder die abgebende Station (Quelle,
    // "abgebende Station löst die Bewegung aus", Entscheidung 2026-07-18)
    // ODER die empfangende Station (Ziel – Sonderfall Auftragseingang, wo es
    // niemanden "Abgebendes" gibt: Station 1 holt sich die erste Karte
    // aktiv ab) mit der bewegenden Person übereinstimmt.
    function bewegungErlaubt(spielId, runde, kartenId) {
      let mitgliedStation = get(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid)).data.get('station', null);
      let vonPosition = resource.data.position;
      let nachPosition = request.resource.data.position;
      let vorherigerStapel = resource.data.get('stapel', null);
      return get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)).data.dorAbgeschlossen == true
        && nachPosition == vonPosition + 1
        && nachPosition <= 6
        && request.resource.data.letzteBewegungVon == request.auth.uid
        && request.resource.data.letzteBewegungAm == request.time
        && request.resource.data.get('stapel', null) == vorherigerStapel
        && (mitgliedStation == vonPosition || mitgliedStation == nachPosition)
        && stapelTorOffen(spielId, runde, vonPosition, vorherigerStapel);
    }

    match /spiele/{spielId} {
      // Lesbar für jede angemeldete Person (auch anonym), die den Code kennt
      // oder rät – das ist die Grundlage des Beitritts-Flusses (Code-Prüfung,
      // Stationsverfügbarkeit VOR dem Beitritt). Enthält bewusst keine
      // sensiblen Felder mehr (siehe geheim/kennung). Ein noch nicht
      // existierendes Dokument ist ebenfalls "lesbar" (liefert schlicht
      // "existiert nicht") – nötig für die Eindeutigkeitsprüfung beim
      // Erstellen eines neuen Codes in createGame.js.
      allow get: if request.auth != null
        && (!exists(/databases/$(database)/documents/spiele/$(spielId)) || istAktiv(resource.data));

      allow create: if request.auth != null
        && request.resource.data.code == spielId
        && request.resource.data.keys().hasAll(['code', 'erstelltAm', 'letzteAktivitaet', 'belegteStationen'])
        && !('hostKennung' in request.resource.data.keys())
        && request.resource.data.belegteStationen == {}
        && request.resource.data.erstelltAm is number
        && request.resource.data.letzteAktivitaet is number;

      // Ändern (z. B. letzteAktivitaet, belegteStationen beim Beitritt): nur
      // wer bereits ein eigenes Teilnehmenden-Dokument in diesem aktiven
      // Spiel hat. code darf nie nachträglich verändert werden.
      allow update: if istTeilnehmer(spielId) && istAktiv(resource.data)
        && request.resource.data.code == resource.data.code
        && !('hostKennung' in request.resource.data.keys());

      allow delete: if false;

      // Enthält ausschliesslich { hostKennung }. KEINE allow read/get-Regel –
      // absichtlich für jeden Client permanent unlesbar. Wird nur intern von
      // anderen Regeln über get()/getAfter() konsultiert (das umgeht die
      // Leseregeln dieses Dokuments nicht etwa unsicher, sondern ist der
      // dafür vorgesehene, dokumentierte Mechanismus).
      match /geheim/kennung {
        allow create: if request.auth != null
          && !exists(/databases/$(database)/documents/spiele/$(spielId)/geheim/kennung)
          && request.resource.data.keys().hasOnly(['hostKennung'])
          && request.resource.data.hostKennung is string;
        allow read, update, delete: if false;
      }

      match /teilnehmende/{uid} {
        // Das eigene Dokument ist immer lesbar. Dokumente ANDERER
        // Teilnehmender sind nur lesbar, wenn sie NICHT der Host-Datensatz
        // sind – der Host-Datensatz enthält zur Validierung eine hostKennung
        // (siehe "allow create" unten) und darf deshalb niemals von jemand
        // anderem als dem Host selbst gelesen werden (sonst könnte sich
        // jede/r Mitspielende die Kennung abgreifen und selbst zum Host
        // erklären).
        allow read: if request.auth != null
          && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && (uid == request.auth.uid || (istTeilnehmer(spielId) && resource.data.rolle != 'host'));

        // Beitritt bzw. Host-Zurückeroberung: eine Person darf ausschliesslich
        // ihr EIGENES Dokument anlegen (Doc-ID == eigene Auth-UID).
        //  - rolle 'spielende'/'beobachtende': die Stationszuweisung selbst
        //    passiert serverseitig in der Anwendungslogik über eine
        //    Firestore-Transaktion (siehe src/game/joinGame.js), nicht in
        //    dieser Regel.
        //  - rolle 'host': nur erlaubt, wenn die mitgeschickte hostKennung
        //    mit der in spiele/{spielId}/geheim/kennung hinterlegten
        //    übereinstimmt. getAfter() statt get(), damit das auch beim
        //    ALLERERSTEN Erstellen funktioniert, wenn geheim/kennung in
        //    genau derselben Transaktion gerade erst entsteht.
        allow create: if request.auth != null
          && uid == request.auth.uid
          && (
            !exists(/databases/$(database)/documents/spiele/$(spielId))
            || istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          )
          && (
            request.resource.data.rolle in ['spielende', 'beobachtende']
            || (
              request.resource.data.rolle == 'host'
              && request.resource.data.hostKennung == getAfter(/databases/$(database)/documents/spiele/$(spielId)/geheim/kennung).data.hostKennung
            )
          );

        // Aktualisieren des eigenen Datensatzes (z. B. eigener Spielzug/eigene
        // Aktivität, ab FEATURE-002). Niemand darf sich per Update nachträglich
        // selbst zum Host machen – das geht ausschliesslich über "create" mit
        // Nachweis der hostKennung.
        allow update: if request.auth != null
          && uid == request.auth.uid
          && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && request.resource.data.rolle == resource.data.rolle;

        allow delete: if false;
      }

      // FEATURE-002: Rundenzustand (Phase, DoR, Zeitstempel).
      // Datenmodell (Option B, freigegeben 2026-07-18):
      //   spiele/{spielId}/runden/{rundenNummer}
      //     -> phase, dorAbgeschlossen, dorAbgeschlossenAm (nicht clientseitig
      //        geprüft, siehe unten), durchlaufzeitStart/-Ende,
      //        bearbeitungszeitStart/-Ende – alle Zeitwerte servergesetzt
      //        (request.time), NIE ein vom Client mitgesendeter Zeitwert.
      match /runden/{runde} {
        allow read: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data);

        // Rundenstart bzw. Rundenwechsel: ausschliesslich der Host löst das
        // aktiv aus (Entscheidung 2026-07-18) – niemals automatisch. Die
        // Durchlaufzeit wird dabei ausschliesslich servergesetzt.
        allow create: if istHost(spielId)
          && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && request.resource.data.dorAbgeschlossen == false
          && request.resource.data.durchlaufzeitStart == request.time
          && request.resource.data.bearbeitungszeitStart == null
          && request.resource.data.durchlaufzeitEnde == null;

        allow update: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && (
            // Fall A: "Definition of Ready abgeschlossen" – Host ODER Team
            // (Entscheidung 2026-07-17). Prüft ausschliesslich das RESULTAT,
            // nicht den Vorzustand: ein zweiter/gleichzeitiger Auslöseversuch
            // (Pre-Mortem-Risiko 1) landet in genau demselben Zweig, wirft
            // also keinen Fehler, ändert aber inhaltlich nichts an einem
            // bereits gesetzten dorAbgeschlossenAm (das hier bewusst nicht
            // client-geprüft wird – der erste erfolgreiche Schreibvorgang
            // gewinnt, alle weiteren sind reine No-Ops mit identischem Ziel-
            // zustand).
            (request.resource.data.dorAbgeschlossen == true
              && request.resource.data.phase == 'dor_abgeschlossen')
            ||
            // Fall B: automatisches Rundenende (letzte Karte im Ziel) – nur
            // mit servergesetztem Zeitstempel, niemals ein Client-Zeitwert.
            // (Nicht Teil der gegebenen automatisierten Regel-Testfälle für
            // dieses Ticket – Stephan sollte das end-to-end im Browser
            // gegenprüfen, sobald die Spielfeld-Oberfläche existiert.)
            (request.resource.data.phase == 'beendet'
              && request.resource.data.durchlaufzeitEnde == request.time
              && resource.data.dorAbgeschlossen == true)
          );

        allow delete: if false;

        // FEATURE-002: eine Karte (Position 0 = Auftragseingang, 1-5 =
        // Stationen, 6 = Ziel). In Runde 2 zusätzlich `stapel: "A" | "B"`
        // (getrennte Stapelzählung, Entscheidung 2026-07-18).
        match /karten/{kartenId} {
          allow read: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data);

          // Karten werden ausschliesslich im selben Vorgang wie der
          // Runden-Start/-Wechsel vom Host angelegt (immer exakt sechs, alle
          // auf Position 0) – kein separates Client-"Nachschieben" einzelner
          // Karten.
          allow create: if istHost(spielId)
            && request.resource.data.position == 0;

          // Kartenbewegung: die abgebende ODER die empfangende Station löst
          // aus (siehe bewegungErlaubt()-Kommentar oben für die Begründung
          // des Sonderfalls Auftragseingang -> Station 1). Beobachtende haben
          // keine `station` zugewiesen und können deshalb nie beide Seiten
          // einer Bewegung treffen (FEATURE-001-Regression: weiterhin keine
          // Schreibrechte auf Spielzüge).
          // OPTIMIERUNG (2026-07-18, gleicher Grund wie bei
          // karteAnPositionUndStapel oben): istTeilnehmer(spielId) hier
          // NICHT mehr separat aufgerufen, um einen weiteren
          // existsAfter()-Aufruf gegen das Firestore-Limit zu sparen -
          // bewegungErlaubt() liest ohnehin per get() das eigene
          // teilnehmende-Dokument, um die eigene Station zu ermitteln; ist
          // die Person kein Teilnehmender, schlaegt dieser get()-Aufruf
          // fehl (Regel lehnt den Zug dann per Auswertungsfehler statt
          // per sauberem false ab) - sicherheitstechnisch gleichwertig
          // abgelehnt, nur mit anderer Fehlerart.
          allow update: if request.auth != null
            && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
            && bewegungErlaubt(spielId, runde, kartenId);

          allow delete: if false;
        }
      }
    }
  }
}
