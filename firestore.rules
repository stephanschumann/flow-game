rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // FEATURE-001: Spiel-Räume.
    // Löst die sperrende Platzhalter-Regel aus TASK-002 ab
    // (`allow read, write: if false;`).
    //
    // Zugriffsmodell OHNE Cloud Functions (Option B, mit Stephan am
    // 2026-07-17 final abgestimmt, siehe Backlog.md FEATURE-001):
    //   - Jede Person meldet sich anonym per Firebase Authentication an und
    //     bekommt dabei eine stabile UID für ihre Browser-Sitzung.
    //   - Zugehörigkeit zu einem Spiel wird darüber geprüft, ob unter
    //     spiele/{spielId}/teilnehmende/{eigene-uid} ein Dokument existiert.
    //   - Die Host-Rolle wird nach Geräteneuladen/Sitzungsverlust über einen
    //     eigenen Schreibvorgang zurückerobert, der die im Spiel hinterlegte
    //     Host-Kennung als Nachweis verlangt.
    //
    // KORREKTUR (2026-07-17, nach echtem Browser-Test durch Stephan):
    //  1. "Missing or insufficient permissions" beim Spiel-Erstellen: die
    //     Regel für teilnehmende/{uid} (rolle=host) prüfte per get() das
    //     übergeordnete spiele/{spielId}-Dokument, das aber in DERSELBEN
    //     Transaktion gerade erst entsteht und für ein normales get() noch
    //     nicht sichtbar ist. Fix: getAfter() statt get() für genau diesen
    //     Vergleich (liefert den Stand NACH allen Schreibvorgängen im
    //     selben Commit – dokumentierte Firestore-Rules-Funktion für exakt
    //     diesen Fall).
    //  2. Beim Beheben von (1) fiel auf: eine neue, noch nicht beigetretene
    //     Person muss spiele/{spielId} lesen können dürfen (Beitritts-Fluss,
    //     Stationsverfügbarkeit vor dem Beitritt) – das hätte hostKennung
    //     offengelegt, wäre es weiterhin Teil dieses Dokuments gewesen.
    //     Fix: hostKennung liegt jetzt in einem eigenen, nie client-lesbaren
    //     Unterdokument spiele/{spielId}/geheim/kennung.

    function istAktiv(spiel) {
      // Verwaiste Spiele (>24h ohne Aktivität, geklärte Frage 7) sind über
      // die Regeln nicht mehr erreichbar, unabhängig von der TTL-Löschung.
      return spiel.letzteAktivitaet > (request.time.toMillis() - 24 * 60 * 60 * 1000);
    }

    function istTeilnehmer(spielId) {
      // existsAfter() statt exists(): beim Beitreten legt joinGame.js in
      // EINEM Commit sowohl das eigene teilnehmende-Dokument an ALS AUCH
      // das Update von belegteStationen/letzteAktivitaet im spiele-Dokument.
      // exists() sähe dabei nur den Stand VOR diesem Commit (Dokument
      // existiert noch nicht) und würde das Update fälschlich ablehnen –
      // dieselbe Fehlerklasse wie das getAfter()-Problem beim Host-Beitritt
      // weiter oben. existsAfter() prüft den Stand NACH allen Schreib-
      // vorgängen desselben Commits und funktioniert dadurch für beide
      // Fälle (Update im selben Commit wie das Anlegen, oder ein Update zu
      // einem späteren Zeitpunkt, wenn das Dokument längst existiert).
      return request.auth != null
        && existsAfter(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid));
    }

    // FEATURE-002: Rundenzustand + Kartenbewegung. Zusätzliche Helfer-
    // Funktionen, siehe Kommentare bei den runden-/karten-Regeln weiter unten.

    function istHost(spielId) {
      // Bewusst flach gehalten (kein Aufruf von istTeilnehmer() von innen
      // heraus) – existsAfter()/get() direkt hier, konsistent mit dem Muster,
      // das in den bereits freigegebenen FEATURE-001-Regeln erfolgreich läuft
      // (dort ruft ebenfalls nie eine Funktion eine andere Funktion auf).
      return request.auth != null
        && existsAfter(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid))
        && get(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid)).data.get('rolle', null) == 'host';
    }

    // FEATURE-003: Auswertung. Zusätzliche Helfer für die Gesamtfreigabe
    // ("ergebnisseFreigegeben"/"ergebnisseFreigegebenAm" auf spiele/{spielId})
    // und die davon abhängige Lesesperre auf den Kennzahlenfeldern der
    // runden-Unterkollektion (Option A, siehe FEATURE-003-Spec).

    // Prüft, ob das laufende Update auf spiele/{spielId} überhaupt eines der
    // beiden Freigabe-Felder verändert. Genutzt, um die bereits bestehende,
    // von FEATURE-001/002 benötigte generische Update-Regel (Stations-
    // zuweisung beim Beitritt, letzteAktivitaet, aktuelleRunde beim Runden-
    // wechsel, …) unverändert offen zu halten, solange diese Freigabe-Felder
    // gar nicht Teil des Updates sind.
    function freigabeFelderBetroffen() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['ergebnisseFreigegeben', 'ergebnisseFreigegebenAm']);
    }

    // Prüft, dass ein Update, das die Freigabe-Felder betrifft, AUSSCHLIESS-
    // LICH diese beiden Felder verändert – verhindert, dass die Freigabe-
    // Aktion "huckepack" noch andere Felder mitändert.
    function nurFreigabeFelderGeaendert() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['ergebnisseFreigegeben', 'ergebnisseFreigegebenAm']);
    }

    // Pre-Mortem Risiko 3: Freigabe nur zulassen, wenn die zuletzt gespielte
    // Runde (spiele/{spielId}.aktuelleRunde, von rundenStart.js bei jedem
    // Rundenstart/-wechsel gesetzt) bereits vollständig beendet ist
    // (phase == 'beendet'). aktuelleRunde ist eine Zahl, Pfadsegmente
    // brauchen aber Strings (siehe Kommentar bei stapelTorSchwelle weiter
    // unten) – deshalb string(...).
    function letzteGespielteRundeBeendet(spielId) {
      return get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(string(resource.data.get('aktuelleRunde', 0)))).data.get('phase', null) == 'beendet';
    }

    // WICHTIG: {runde} ist als Firestore-Pfadsegment (match /runden/{runde})
    // IMMER ein String ("1"/"2"/"3"), nie eine Zahl – deshalb hier bewusst
    // String-Literale statt Zahlen-Literale vergleichen. Ein Vergleich mit
    // Zahlen-Literalen hätte hier für JEDE Runde still auf den else-Zweig (1)
    // durchfallen können, ohne einen Fehler zu werfen (falscher, aber stiller
    // Wert statt korrekt 6/3/1).
    function stapelTorSchwelle(runde) {
      return runde == '1' ? 6 : (runde == '2' ? 3 : 1);
    }

    // Zählt, wie viele der (bis zu) sechs Karten der Runde die `position`
    // BEREITS ERREICHT ODER VERLASSEN haben (position >= die geprüfte
    // Position), optional zusätzlich nach `stapel` gefiltert (Runde 2: die
    // zwei Dreierstapel werden GETRENNT gezählt, Entscheidung 2026-07-18 –
    // kein einmaliges Freischalten über die Gesamtsumme).
    //
    // BUGFIX (2026-07-18, live in Production gefunden beim Bau der
    // Spielbrett-Oberfläche, siehe Abschlussbericht an Stephan): Ursprünglich
    // zählte diese Funktion nur Karten GENAU AN `position` (daten.position ==
    // position). Das öffnet das Tor zwar korrekt beim SECHSTEN Ankommen,
    // schließt es aber sofort wieder, sobald die ERSTE Karte durch das
    // offene Tor weiterzieht (dann stehen nur noch fünf Karten GENAU an
    // `position`, 5 < Schwelle 6) – jede Karte AUSSER der ersten wurde
    // dadurch faelschlich abgelehnt ("Missing or insufficient permissions"),
    // real reproduziert: Karte 1 von Station 1 zu Station 2 gelang, Karten
    // 2-6 scheiterten alle. Fix: `>=` statt `==` – eine Karte, die die
    // Position bereits verlassen hat (an einer höheren Position steht), hat
    // denknotwendig auch `position` durchlaufen und zählt weiterhin für die
    // Tor-Schwelle dieser Position. Einmal offen, bleibt das Tor damit für
    // den Rest der Runde offen, wie in den Akzeptanzkriterien beschrieben.
    //
    // Sicherheitsregeln können keine Sammlungs-Query ausführen (Pre-Mortem-
    // Risiko 3). Da pro Runde immer genau sechs, namentlich bekannte
    // Karten-IDs existieren (karte-1 .. karte-6), werden alle sechs einzeln
    // per get() gelesen und gezählt – das bleibt klar unter dem Limit an
    // get()/exists()-Aufrufen je Regelauswertung.
    function karteAnPositionUndStapel(spielId, runde, kartenId, position, stapel) {
      // OPTIMIERUNG (nach echtem Testlauf mit Stephan, 2026-07-18): kein
      // separates exists()-Vorab-Check mehr - pro Karte nur noch EIN
      // get()-Aufruf statt zwei. Sicher, weil laut Architektur
      // (rundenStart.js) bei jedem Rundenstart immer exakt alle sechs
      // Karten (karte-1..karte-6) ATOMAR zusammen angelegt werden; sobald
      // DoR abgeschlossen ist (Vorbedingung in bewegungErlaubt()),
      // existieren deshalb garantiert alle sechs. Grund: der reale
      // Firestore-Testlauf zeigte "evaluation error ... Function: [exists]"
      // fuer mehrere Kartenbewegungs-/Stapel-Tor-Szenarien - Ursache war
      // das dokumentierte Firestore-Limit von 10 get()/exists()-Aufrufen
      // pro Einzeldokument-Request: die alte Variante (exists() + bedingtes
      // get() je Karte) brauchte bis zu 12 Aufrufe allein fuer die sechs
      // Karten, zusammen mit den uebrigen Aufrufen in bewegungErlaubt()
      // weit ueber dem Limit. Mit nur einem get() je Karte bleibt die
      // gesamte Regelauswertung fuer eine Kartenbewegung bei maximal 9.
      let daten = get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)/karten/$(kartenId)).data;
      return daten.position >= position
        && (stapel == null || daten.get('stapel', null) == stapel)
        ? 1 : 0;
    }

    function anzahlAnPosition(spielId, runde, position, stapel) {
      return karteAnPositionUndStapel(spielId, runde, 'karte-1', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-2', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-3', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-4', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-5', position, stapel)
           + karteAnPositionUndStapel(spielId, runde, 'karte-6', position, stapel);
    }

    function stapelTorOffen(spielId, runde, vonPosition, stapel) {
      // Der Übergang vom Auftragseingang (Position 0) zu Station 1 ist immer
      // offen, unabhängig von der Rundenschwelle (Entscheidung 2026-07-18) –
      // deshalb hier keine Zählung/kein zusätzlicher get()-Aufwand nötig.
      return vonPosition == 0
        || anzahlAnPosition(spielId, runde, vonPosition, stapel) >= stapelTorSchwelle(runde);
    }

    // Bewegung ist erlaubt, wenn entweder die abgebende Station (Quelle,
    // "abgebende Station löst die Bewegung aus", Entscheidung 2026-07-18)
    // ODER die empfangende Station (Ziel – Sonderfall Auftragseingang, wo es
    // niemanden "Abgebendes" gibt: Station 1 holt sich die erste Karte
    // aktiv ab) mit der bewegenden Person übereinstimmt.
    function bewegungErlaubt(spielId, runde, kartenId) {
      let mitgliedStation = get(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(request.auth.uid)).data.get('station', null);
      let vonPosition = resource.data.position;
      let nachPosition = request.resource.data.position;
      let vorherigerStapel = resource.data.get('stapel', null);
      return get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)).data.dorAbgeschlossen == true
        && nachPosition == vonPosition + 1
        && nachPosition <= 6
        && request.resource.data.letzteBewegungVon == request.auth.uid
        && request.resource.data.letzteBewegungAm == request.time
        && request.resource.data.get('stapel', null) == vorherigerStapel
        && (mitgliedStation == vonPosition || mitgliedStation == nachPosition)
        && stapelTorOffen(spielId, runde, vonPosition, vorherigerStapel);
    }

    // FEATURE-004: Runde 4 (Kontextwechsel). Wiederverwendet die bestehende
    // runden/{runde}-Struktur oben UNVERÄNDERT (DoR, Host-Rundenstart,
    // servergesetzte Zeitstempel, Fall-B-Rundenende) – siehe "Wiederverwendungs-
    // /Regressionsnachweis" in tests/game-round4.security.rules.test.js, dort
    // bereits GRÜN, weil {runde} ein Wildcard-Pfadsegment ist. Neu sind
    // ausschliesslich die beiden Unterkollektionen elemente/{elementId} und
    // fortschritt/{uid} unter runden/{runde} (siehe deren match-Blöcke weiter
    // unten) und die folgenden Helfer-Funktionen dafür. Bewusst auf dieser
    // TOP-LEVEL-Ebene definiert (statt innerhalb von match /runden/{runde}),
    // exakt nach demselben Muster wie istAktiv/istTeilnehmer/istHost/
    // bewegungErlaubt oben – kein neu erfundenes Scoping-Muster.
    //
    // Datenmodell (NAMENSGEBUNG aus tests/game-round4.*.test.js, "eine
    // gemeinsame Unterkollektion mit Typ-Feld" statt zwei getrennter):
    //   elemente/{elementId}: typ ('wuerfel'|'laenderkarte'), reihenfolge
    //     (1..12, feste Startreihenfolge), position (1..5 aktuell zuständige
    //     Person, 6 = fertig bei Spieler 5), angekommenAm (servergesetzt,
    //     Grundlage FIFO AK 8), bei Länderkarten zusätzlich land + staedte,
    //     bei Würfeln wurfAnzahl/letzterWurf (rein clientseitig, siehe
    //     Pre-Mortem-Risiko 9 – bewusst NICHT serverseitig geprüft).
    //
    //   staedte: BEWUSST eine MAP mit String-Schlüsseln "0".."4" (append-only,
    //     Einfüge-Reihenfolge = Schlüssel-Reihenfolge), NICHT ein Array von
    //     Objekten. Grund (2026-07-20, echter Emulator-Testlauf durch Stephan,
    //     siehe Abschlussbericht): Firestore lehnt serverTimestamp() als
    //     Feldwert INNERHALB eines Arrays grundsätzlich ab ("serverTimestamp()
    //     is not currently supported inside arrays") – das gilt auch für ein
    //     Objekt, das per arrayUnion()/direkter Array-Zuweisung in ein Array
    //     geschrieben wird. Da jeder Städte-Eintrag laut AK 14 einen ECHTEN
    //     servergesetzten Zeitstempel tragen MUSS (Grundlage der späteren
    //     deterministischen Dublettenerkennung in qualitaetsauswertung.js),
    //     ist ein Array hier technisch unmöglich. Firestore erlaubt
    //     serverTimestamp() dagegen uneingeschränkt innerhalb von Map-Feldern
    //     – deshalb: staedte: { "0": { stadt, von, am }, "1": {...}, ... }.
    //     Jeder Eintrag bleibt einzeln adressierbar (wichtig für den
    //     Append-only-Prefix-Vergleich unten), Größe weiterhin per .size().
    //   fortschritt/{uid}: letzterAbgeschlossenerTyp je Person, Grundlage der
    //     Wechselzwang-Regel (AK 9).
    //
    // Zuständigkeit folgt AUSDRÜCKLICH teilnehmende/{uid}.rundeVierPosition –
    // bewusst NICHT dasselbe Feld wie `station` aus FEATURE-002 (Pre-Mortem-
    // Risiko 10: eine Person kann in Runde 1-3 an einer anderen Position
    // stehen als in Runde 4, siehe "Zuständigkeit über Person/uid"-Testblock).
    function rundeVierPositionVon(spielId, uid) {
      return get(/databases/$(database)/documents/spiele/$(spielId)/teilnehmende/$(uid)).data.get('rundeVierPosition', null);
    }

    // Fortschritt-Dokumente werden für alle fünf Spielenden ATOMAR beim
    // Rundenstart angelegt (analog zur Garantie bei den sechs Karten aus
    // FEATURE-002, siehe Kommentar bei karteAnPositionUndStapel oben) –
    // deshalb hier bewusst ein direktes get() ohne vorherige exists()-Prüfung
    // (spart einen Aufruf gegen das Get()/Exists()-Kontingent, Pre-Mortem-
    // Risiko 6).
    function rundeVierFortschrittTyp(spielId, runde, uid) {
      return get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)/fortschritt/$(uid)).data.get('letzterAbgeschlossenerTyp', null);
    }

    // Wechselzwang (AK 9): Der Elementtyp des jetzt zu bearbeitenden Elements
    // (resource.data.typ) darf NICHT identisch mit dem zuletzt von dieser
    // Person abgeschlossenen Typ sein. Zu Rundenbeginn (noch kein
    // abgeschlossener Typ) ist beides erlaubt.
    function rundeVierWechselzwangErlaubt(spielId, runde) {
      let letzterTyp = rundeVierFortschrittTyp(spielId, runde, request.auth.uid);
      return letzterTyp == null || letzterTyp != resource.data.typ;
    }

    // FIFO (AK 8): Prüft, ob unter den sechs namentlich bekannten Geschwister-
    // Elementen DESSELBEN Typs (wuerfel-1..6 bzw. karte-1..6 – Sicherheits-
    // regeln können keine Sammlungs-Query ausführen, Pre-Mortem-Risiko 6,
    // gleiches Muster wie karteAnPositionUndStapel oben) eines existiert, das
    // an DERSELBEN abgebenden Position noch wartet (position == vonPosition)
    // UND früher dort angekommen ist (angekommenAm < eigenesAngekommenAm) als
    // das gerade bewegte Element selbst. `kandidatId == elementId`
    // überspringt das bewegte Element selbst OHNE zusätzlichen get()-Aufruf
    // (CEL wertet den Ternary-Zweig nur bei Bedarf aus) – hält die Gesamt-
    // auswertung bei maximal 9 get()-Aufrufen (1 istAktiv + 1 dorAbgeschlossen
    // + 1 rundeVierPositionVon + 1 rundeVierFortschrittTyp + 5 FIFO-Gets nach
    // Selbstausschluss), siehe Abschlussbericht.
    function rundeVierElementAngekommenVor(spielId, runde, elementId, kandidatId, vonPosition, eigenesAngekommenAm) {
      return kandidatId == elementId ? 0 : (
        get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)/elemente/$(kandidatId)).data.position == vonPosition
        && get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)/elemente/$(kandidatId)).data.angekommenAm < eigenesAngekommenAm
        ? 1 : 0
      );
    }

    function rundeVierAnzahlFrueherWartend(spielId, runde, elementId, vonPosition, eigenesAngekommenAm) {
      return resource.data.typ == 'wuerfel'
        ? rundeVierElementAngekommenVor(spielId, runde, elementId, 'wuerfel-1', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'wuerfel-2', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'wuerfel-3', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'wuerfel-4', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'wuerfel-5', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'wuerfel-6', vonPosition, eigenesAngekommenAm)
        : rundeVierElementAngekommenVor(spielId, runde, elementId, 'karte-1', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'karte-2', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'karte-3', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'karte-4', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'karte-5', vonPosition, eigenesAngekommenAm)
          + rundeVierElementAngekommenVor(spielId, runde, elementId, 'karte-6', vonPosition, eigenesAngekommenAm);
    }

    // Kettenfortschritt (AK 7): Ein Element darf ausschliesslich um GENAU
    // einen Schritt an die nächste Person weitergegeben werden (niemals
    // rückwärts, niemals eine Person überspringen, niemals direkt auf
    // "fertig" springen – alle drei Fälle scheitern bereits an `nachPosition
    // == vonPosition + 1`), ausschliesslich durch die Person, bei der es laut
    // `rundeVierPosition` gerade zuständig ist, ausschliesslich nach
    // abgeschlossener Definition of Ready, und nur wenn Wechselzwang UND FIFO
    // das zulassen.
    //
    // Ankunftszeitstempel (BUGFIX 2026-07-20, zweiter Fund direkt nach dem
    // Array->Map-Umbau bei staedte, siehe rundeVierStaedteAngehaengt() unten):
    // Für einen Würfel bleibt es dabei, dass `angekommenAm` bei JEDEM
    // Kettenfortschritt zwingend frisch servergesetzt sein muss (sonst könnte
    // FIFO durch Wiederverwenden eines alten Zeitstempels umgangen werden).
    // Für eine Länderkarte ist der servergesetzte Nachweis der Ankunft an der
    // NEUEN Position bereits durch den neu angehängten Städte-Eintrag selbst
    // erbracht (`neu[neuerSchluessel].am == request.time`, erzwungen von
    // rundeVierStaedteAngehaengt()) – ein Client, der eine Karte weiterreicht,
    // muss deshalb `angekommenAm` NICHT zusätzlich anfassen; erlaubt ist bei
    // Länderkarten daher entweder ein frischer servergesetzter Zeitstempel
    // (falls ein Client ihn trotzdem mitschickt) ODER ein unveränderter alter
    // Wert. Sicherheitstechnisch unkritisch: ein Client kann `angekommenAm`
    // damit weiterhin nicht auf einen selbstgewählten Wert setzen, sondern nur
    // zwischen "jetzt" und "unverändert" wählen.
    function rundeVierKettenfortschrittErlaubt(spielId, runde, elementId) {
      let vonPosition = resource.data.position;
      let nachPosition = request.resource.data.position;
      return get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)).data.get('dorAbgeschlossen', false) == true
        && rundeVierPositionVon(spielId, request.auth.uid) == vonPosition
        && nachPosition == vonPosition + 1
        && nachPosition <= 6
        && (request.resource.data.angekommenAm == request.time
          || (resource.data.typ == 'laenderkarte' && request.resource.data.angekommenAm == resource.data.angekommenAm))
        && rundeVierWechselzwangErlaubt(spielId, runde)
        && rundeVierAnzahlFrueherWartend(spielId, runde, elementId, vonPosition, resource.data.angekommenAm) == 0;
    }

    // Würfel-Zwischenwurf (AK 10): Ein Wurf ≤3 bleibt bei derselben Person
    // stehen (kein Kettenfortschritt, keine FIFO-/Wechselzwang-Prüfung nötig,
    // weil das Element dadurch nicht "fertig" wird) – der konkrete Wert wird
    // bewusst NICHT geprüft (Pre-Mortem-Risiko 9, akzeptiertes Restrisiko,
    // analog CatTube).
    function rundeVierWuerfelZwischenwurfErlaubt(spielId, runde) {
      return get(/databases/$(database)/documents/spiele/$(spielId)/runden/$(runde)).data.get('dorAbgeschlossen', false) == true
        && rundeVierPositionVon(spielId, request.auth.uid) == resource.data.position
        && request.resource.data.position == resource.data.position;
    }

    // Append-only Städte-MAP (AK 14, BUGFIX 2026-07-20 – siehe Datenmodell-
    // Kommentar bei rundeVierPositionVon() weiter oben): ursprünglich als
    // Array von Objekten { stadt, von, am: serverTimestamp() } modelliert;
    // echter Emulator-Testlauf zeigte, dass Firestore serverTimestamp() als
    // Feldwert innerhalb eines Arrays grundsätzlich ablehnt (dokumentierte
    // SDK-Einschränkung, kein Regel-Bug) – der Schreibversuch scheiterte
    // bereits CLIENTSEITIG, bevor überhaupt eine Regel ausgewertet wurde.
    // Fix: `staedte` ist jetzt eine MAP mit String-Schlüsseln "0".."4"
    // (Einfüge-Reihenfolge = Schlüssel-Reihenfolge), Firestore erlaubt
    // serverTimestamp() innerhalb von Map-Feldern uneingeschränkt. Die
    // Prüf-Logik selbst bleibt inhaltlich UNVERÄNDERT (1:1 von Array-Index auf
    // String-Schlüssel übertragen): Die neue Map muss GENAU einen Eintrag
    // länger sein, die bereits vorhandenen Einträge müssen inhaltlich
    // (Stadt + eintragende Person) UNVERÄNDERT bleiben, und der neu
    // angehängte Eintrag muss von der schreibenden Person selbst stammen und
    // einen servergesetzten Zeitstempel tragen (Grundlage der
    // deterministischen Dublettenerkennung, Pre-Mortem-Risiko 1). Bewusst OHNE
    // Prüfung des `am`-Felds bereits vorhandener Einträge (nur Stadt+von) –
    // ein Client, der eine Karte weiterreicht, kennt deren bereits
    // gespeicherten Server-Zeitstempel nicht zwangsläufig exakt genug, um ihn
    // byteidentisch zurückzusenden; das Verbot einer inhaltlichen Änderung
    // (Stadt/Person) bleibt trotzdem durchgesetzt.
    function rundeVierStaedtePrefixUnveraendert(alt, neu) {
      return alt.size() == 0
        || (neu['0'].stadt == alt['0'].stadt && neu['0'].von == alt['0'].von && (alt.size() == 1
          || (neu['1'].stadt == alt['1'].stadt && neu['1'].von == alt['1'].von && (alt.size() == 2
            || (neu['2'].stadt == alt['2'].stadt && neu['2'].von == alt['2'].von && (alt.size() == 3
              || (neu['3'].stadt == alt['3'].stadt && neu['3'].von == alt['3'].von && (alt.size() == 4
                || (neu['4'].stadt == alt['4'].stadt && neu['4'].von == alt['4'].von)))))))));
    }

    function rundeVierStaedteAngehaengt() {
      let alt = resource.data.get('staedte', {});
      let neu = request.resource.data.get('staedte', {});
      let neuerSchluessel = string(alt.size());
      return neu.size() == alt.size() + 1
        && rundeVierStaedtePrefixUnveraendert(alt, neu)
        && neu[neuerSchluessel].von == request.auth.uid
        && neu[neuerSchluessel].am == request.time;
    }

    match /spiele/{spielId} {
      // Lesbar für jede angemeldete Person (auch anonym), die den Code kennt
      // oder rät – das ist die Grundlage des Beitritts-Flusses (Code-Prüfung,
      // Stationsverfügbarkeit VOR dem Beitritt). Enthält bewusst keine
      // sensiblen Felder mehr (siehe geheim/kennung). Ein noch nicht
      // existierendes Dokument ist ebenfalls "lesbar" (liefert schlicht
      // "existiert nicht") – nötig für die Eindeutigkeitsprüfung beim
      // Erstellen eines neuen Codes in createGame.js.
      allow get: if request.auth != null
        && (!exists(/databases/$(database)/documents/spiele/$(spielId)) || istAktiv(resource.data));

      allow create: if request.auth != null
        && request.resource.data.code == spielId
        && request.resource.data.keys().hasAll(['code', 'erstelltAm', 'letzteAktivitaet', 'belegteStationen'])
        && !('hostKennung' in request.resource.data.keys())
        && request.resource.data.belegteStationen == {}
        && request.resource.data.erstelltAm is number
        && request.resource.data.letzteAktivitaet is number;

      // Ändern (z. B. letzteAktivitaet, belegteStationen beim Beitritt,
      // aktuelleRunde beim Rundenwechsel): nur wer bereits ein eigenes
      // Teilnehmenden-Dokument in diesem aktiven Spiel hat. code darf nie
      // nachträglich verändert werden.
      //
      // FEATURE-003: Die Gesamtfreigabe der Ergebnisse (ergebnisseFreigegeben/
      // ergebnisseFreigegebenAm) läuft über genau dieses Update, ist aber ein
      // Sonderfall mit eigenen, engeren Voraussetzungen (Fall B unten) –
      // diese generische Regel erlaubte vor FEATURE-003 JEDER teilnehmenden
      // Person das Setzen beliebiger Felder, also auch der Freigabe-Felder
      // (siehe Kommentar in tests/game-evaluation.security.rules.test.js).
      allow update: if istTeilnehmer(spielId) && istAktiv(resource.data)
        && request.resource.data.code == resource.data.code
        && !('hostKennung' in request.resource.data.keys())
        && (
          // Fall A: normale Aktualisierung – Freigabe-Felder bleiben dabei
          // unangetastet, unverändertes Verhalten aus FEATURE-001/FEATURE-002.
          !freigabeFelderBetroffen()
          ||
          // Fall B: FEATURE-003 Gesamtfreigabe – ausschliesslich der Host,
          // nur diese beiden Felder, nur wenn die letzte gespielte Runde
          // bereits vollständig beendet ist (Pre-Mortem Risiko 3), und
          // ergebnisseFreigegebenAm MUSS ein echter Server-Zeitstempel sein
          // (analog den *Start/*Ende-Zeitstempeln aus FEATURE-002 – niemals
          // ein vom Client mitgesendeter Zeitwert). Prüft bewusst nur das
          // RESULTAT (== true), nicht den Vorzustand: ein zweiter/gleich-
          // zeitiger Auslöseversuch (Pre-Mortem Risiko 1, z. B. Doppelklick)
          // landet im selben Zweig und ist ein wirkungsloses No-Op statt
          // eines Fehlers – gleiches Muster wie die DoR-Idempotenz aus
          // FEATURE-002.
          (
            istHost(spielId)
            && nurFreigabeFelderGeaendert()
            && request.resource.data.ergebnisseFreigegeben == true
            && request.resource.data.ergebnisseFreigegebenAm == request.time
            && letzteGespielteRundeBeendet(spielId)
          )
        );

      allow delete: if false;

      // Enthält ausschliesslich { hostKennung }. KEINE allow read/get-Regel –
      // absichtlich für jeden Client permanent unlesbar. Wird nur intern von
      // anderen Regeln über get()/getAfter() konsultiert (das umgeht die
      // Leseregeln dieses Dokuments nicht etwa unsicher, sondern ist der
      // dafür vorgesehene, dokumentierte Mechanismus).
      match /geheim/kennung {
        allow create: if request.auth != null
          && !exists(/databases/$(database)/documents/spiele/$(spielId)/geheim/kennung)
          && request.resource.data.keys().hasOnly(['hostKennung'])
          && request.resource.data.hostKennung is string;
        allow read, update, delete: if false;
      }

      match /teilnehmende/{uid} {
        // Das eigene Dokument ist immer lesbar. Dokumente ANDERER
        // Teilnehmender sind nur lesbar, wenn sie NICHT der Host-Datensatz
        // sind – der Host-Datensatz enthält zur Validierung eine hostKennung
        // (siehe "allow create" unten) und darf deshalb niemals von jemand
        // anderem als dem Host selbst gelesen werden (sonst könnte sich
        // jede/r Mitspielende die Kennung abgreifen und selbst zum Host
        // erklären).
        allow read: if request.auth != null
          && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && (uid == request.auth.uid || (istTeilnehmer(spielId) && resource.data.rolle != 'host'));

        // Beitritt bzw. Host-Zurückeroberung: eine Person darf ausschliesslich
        // ihr EIGENES Dokument anlegen (Doc-ID == eigene Auth-UID).
        //  - rolle 'spielende'/'beobachtende': die Stationszuweisung selbst
        //    passiert serverseitig in der Anwendungslogik über eine
        //    Firestore-Transaktion (siehe src/game/joinGame.js), nicht in
        //    dieser Regel.
        //  - rolle 'host': nur erlaubt, wenn die mitgeschickte hostKennung
        //    mit der in spiele/{spielId}/geheim/kennung hinterlegten
        //    übereinstimmt. getAfter() statt get(), damit das auch beim
        //    ALLERERSTEN Erstellen funktioniert, wenn geheim/kennung in
        //    genau derselben Transaktion gerade erst entsteht.
        allow create: if request.auth != null
          && uid == request.auth.uid
          && (
            !exists(/databases/$(database)/documents/spiele/$(spielId))
            || istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          )
          && (
            request.resource.data.rolle in ['spielende', 'beobachtende']
            || (
              request.resource.data.rolle == 'host'
              && request.resource.data.hostKennung == getAfter(/databases/$(database)/documents/spiele/$(spielId)/geheim/kennung).data.hostKennung
            )
          );

        // Aktualisieren des eigenen Datensatzes (z. B. eigener Spielzug/eigene
        // Aktivität, ab FEATURE-002). Niemand darf sich per Update nachträglich
        // selbst zum Host machen – das geht ausschliesslich über "create" mit
        // Nachweis der hostKennung.
        allow update: if request.auth != null
          && uid == request.auth.uid
          && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && request.resource.data.rolle == resource.data.rolle;

        allow delete: if false;
      }

      // FEATURE-002: Rundenzustand (Phase, DoR, Zeitstempel).
      // Datenmodell (Option B, freigegeben 2026-07-18):
      //   spiele/{spielId}/runden/{rundenNummer}
      //     -> phase, dorAbgeschlossen, dorAbgeschlossenAm (nicht clientseitig
      //        geprüft, siehe unten), durchlaufzeitStart/-Ende,
      //        bearbeitungszeitStart/-Ende – alle Zeitwerte servergesetzt
      //        (request.time), NIE ein vom Client mitgesendeter Zeitwert.
      match /runden/{runde} {
        // FEATURE-003: Solange eine Runde noch läuft (phase != 'beendet'),
        // bleibt sie wie in FEATURE-002 für alle Teilnehmenden lesbar
        // (Regressionsschutz Live-Spielfeld). Erst eine BEENDETE Runde
        // enthält überhaupt Kennzahlenfelder (Option A) – für die gilt: nur
        // der Host darf jederzeit lesen, alle anderen erst NACH der
        // Gesamtfreigabe (spiele/{spielId}.ergebnisseFreigegeben == true).
        // Sicherheitsregeln können kein Feld-Filtering vornehmen (immer das
        // GANZE Dokument), das ist hier unschädlich, weil die Kennzahlen-
        // felder ohnehin erst ab phase == 'beendet' befüllt sind.
        allow read: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && (
            resource.data.get('phase', null) != 'beendet'
            || get(/databases/$(database)/documents/spiele/$(spielId)).data.get('ergebnisseFreigegeben', false) == true
            || istHost(spielId)
          );

        // Rundenstart bzw. Rundenwechsel: ausschliesslich der Host löst das
        // aktiv aus (Entscheidung 2026-07-18) – niemals automatisch. Die
        // Durchlaufzeit wird dabei ausschliesslich servergesetzt.
        allow create: if istHost(spielId)
          && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && request.resource.data.dorAbgeschlossen == false
          && request.resource.data.durchlaufzeitStart == request.time
          && request.resource.data.bearbeitungszeitStart == null
          && request.resource.data.durchlaufzeitEnde == null;

        allow update: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
          && (
            // Fall A: "Definition of Ready abgeschlossen" – Host ODER Team
            // (Entscheidung 2026-07-17). Prüft ausschliesslich das RESULTAT,
            // nicht den Vorzustand: ein zweiter/gleichzeitiger Auslöseversuch
            // (Pre-Mortem-Risiko 1) landet in genau demselben Zweig, wirft
            // also keinen Fehler, ändert aber inhaltlich nichts an einem
            // bereits gesetzten dorAbgeschlossenAm (das hier bewusst nicht
            // client-geprüft wird – der erste erfolgreiche Schreibvorgang
            // gewinnt, alle weiteren sind reine No-Ops mit identischem Ziel-
            // zustand).
            (request.resource.data.dorAbgeschlossen == true
              && request.resource.data.phase == 'dor_abgeschlossen')
            ||
            // Fall B: automatisches Rundenende (letzte Karte im Ziel) – nur
            // mit servergesetztem Zeitstempel, niemals ein Client-Zeitwert.
            // (Nicht Teil der gegebenen automatisierten Regel-Testfälle für
            // dieses Ticket – Stephan sollte das end-to-end im Browser
            // gegenprüfen, sobald die Spielfeld-Oberfläche existiert.)
            (request.resource.data.phase == 'beendet'
              && request.resource.data.durchlaufzeitEnde == request.time
              && resource.data.dorAbgeschlossen == true)
          );

        allow delete: if false;

        // FEATURE-002: eine Karte (Position 0 = Auftragseingang, 1-5 =
        // Stationen, 6 = Ziel). In Runde 2 zusätzlich `stapel: "A" | "B"`
        // (getrennte Stapelzählung, Entscheidung 2026-07-18).
        match /karten/{kartenId} {
          allow read: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data);

          // Karten werden ausschliesslich im selben Vorgang wie der
          // Runden-Start/-Wechsel vom Host angelegt (immer exakt sechs, alle
          // auf Position 0) – kein separates Client-"Nachschieben" einzelner
          // Karten.
          allow create: if istHost(spielId)
            && request.resource.data.position == 0;

          // Kartenbewegung: die abgebende ODER die empfangende Station löst
          // aus (siehe bewegungErlaubt()-Kommentar oben für die Begründung
          // des Sonderfalls Auftragseingang -> Station 1). Beobachtende haben
          // keine `station` zugewiesen und können deshalb nie beide Seiten
          // einer Bewegung treffen (FEATURE-001-Regression: weiterhin keine
          // Schreibrechte auf Spielzüge).
          // OPTIMIERUNG (2026-07-18, gleicher Grund wie bei
          // karteAnPositionUndStapel oben): istTeilnehmer(spielId) hier
          // NICHT mehr separat aufgerufen, um einen weiteren
          // existsAfter()-Aufruf gegen das Firestore-Limit zu sparen -
          // bewegungErlaubt() liest ohnehin per get() das eigene
          // teilnehmende-Dokument, um die eigene Station zu ermitteln; ist
          // die Person kein Teilnehmender, schlaegt dieser get()-Aufruf
          // fehl (Regel lehnt den Zug dann per Auswertungsfehler statt
          // per sauberem false ab) - sicherheitstechnisch gleichwertig
          // abgelehnt, nur mit anderer Fehlerart.
          allow update: if request.auth != null
            && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
            && bewegungErlaubt(spielId, runde, kartenId);

          allow delete: if false;
        }

        // FEATURE-004: Runde 4 (Kontextwechsel) – Datenmodell und Helfer-
        // Funktionen siehe Kommentar bei rundeVierPositionVon() weiter oben
        // (top-level, gleiches Scoping-Muster wie istHost/bewegungErlaubt).
        match /elemente/{elementId} {
          allow read: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data);

          // Alle zwölf Elemente werden ausschliesslich im selben Vorgang wie
          // der Runde-4-Start vom Host angelegt (analog zu den sechs Karten
          // aus FEATURE-002) – kein separates Client-"Nachschieben".
          allow create: if istHost(spielId)
            && request.resource.data.typ in ['wuerfel', 'laenderkarte']
            && request.resource.data.position == 1;

          // Zwei grundverschiedene, erlaubte Update-Formen:
          //  (a) Würfel-Zwischenwurf: bleibt bei derselben Person stehen.
          //  (b) Kettenfortschritt: ein Schritt an die nächste Person, bei
          //      Länderkarten zusätzlich zwingend mit genau einem neuen,
          //      angehängten Städte-Eintrag (AK 11-14).
          // Bewusst KEIN separater istTeilnehmer()-Aufruf hier (gleiche
          // Optimierung wie bei bewegungErlaubt() oben) – eine Nicht-
          // Teilnehmer-Person hat kein eigenes teilnehmende-Dokument, wodurch
          // rundeVierPositionVon() bereits mit einem Auswertungsfehler
          // scheitert (sicherheitstechnisch gleichwertig abgelehnt).
          allow update: if request.auth != null
            && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
            && request.resource.data.typ == resource.data.typ
            && (
              (resource.data.typ == 'wuerfel'
                && request.resource.data.position == resource.data.position
                && rundeVierWuerfelZwischenwurfErlaubt(spielId, runde))
              ||
              (rundeVierKettenfortschrittErlaubt(spielId, runde, elementId)
                && (resource.data.typ == 'wuerfel' || rundeVierStaedteAngehaengt()))
            );

          allow delete: if false;
        }

        // fortschritt/{uid}: nicht Teil der gegebenen automatisierten Regel-
        // Testfälle für dieses Ticket (siehe Kopf von
        // tests/game-round4.security.rules.test.js – dort ausschliesslich per
        // withSecurityRulesDisabled() geseedet), trotzdem mit einer
        // realistischen, restriktiven Regel versehen (kein dauerhaft offener
        // Pfad): nur die eigene Person darf ihren eigenen Fortschritt
        // schreiben, nur der Host darf die initialen fünf Dokumente beim
        // Rundenstart anlegen.
        match /fortschritt/{uid} {
          allow read: if istTeilnehmer(spielId) && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data);

          allow create: if istHost(spielId)
            && request.resource.data.letzterAbgeschlossenerTyp == null;

          allow update: if request.auth != null && uid == request.auth.uid
            && istAktiv(get(/databases/$(database)/documents/spiele/$(spielId)).data)
            && request.resource.data.letzterAbgeschlossenerTyp in ['wuerfel', 'laenderkarte'];

          allow delete: if false;
        }
      }
    }
  }
}
